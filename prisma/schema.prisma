// FarmLabs — Auth.js + SQLite (use PostgreSQL in production)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  /// X handle (no @) — for profile link; set on Twitter sign-in
  xHandle       String?
  accounts      Account[]
  sessions      Session[]

  /// Public Solana wallet address (Pump.fun) after connecting
  wallet        String?
  projects      Project[]
  escrowBuys    EscrowOrder[] @relation("BuyerOrders")
  escrowSales   EscrowOrder[] @relation("SellerOrders")
  reportsFiled  ProjectReport[] @relation("ReportsFiled")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token      String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortPitch     String
  description    String   @default("")
  groupType      String   @default("PUBLIC")
  accessType     String   @default("FREE")
  /// Price for paid access; currency in priceCurrency (USDC or SOL)
  priceAmount    Float?
  priceCurrency  String?  // USDC | SOL
  category       String?
  rules          String   @default("")
  deliveryPolicy String   @default("")
  /// Optional community logo for listing cards (`/uploads/...` or public https URL)
  communityImage String?
  /// JSON string array: up to 3 image URLs (same rules as communityImage); SQLite — no Prisma Json type
  detailImages   String?
  telegram       String?
  discord        String?
  launchPlan     String   @default("")
  expectedLaunch String?
  launchStatus   String   @default("UPCOMING")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  escrowOrders   EscrowOrder[]
  reports        ProjectReport[]
}

model EscrowOrder {
  id          String   @id @default(cuid())
  projectId   String
  buyerId     String
  sellerId    String
  amount      Float
  /// USDC | SOL
  currency    String
  status      String   @default("FUNDED")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  releasedAt  DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  seller      User     @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  review      EscrowReview?
}

/// Buyer feedback on a completed escrow (one per order).
model EscrowReview {
  id            String   @id @default(cuid())
  escrowOrderId String   @unique
  rating        Int
  comment       String   @default("")
  createdAt     DateTime @default(now())
  order         EscrowOrder @relation(fields: [escrowOrderId], references: [id], onDelete: Cascade)
}

/// User-submitted report about a listing.
model ProjectReport {
  id         String   @id @default(cuid())
  projectId  String
  reporterId String
  reason     String
  message    String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter User    @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([projectId, reporterId])
  @@index([projectId])
  @@index([reporterId])
}

