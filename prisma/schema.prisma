// FarmLabs — Auth.js + SQLite (ganti ke PostgreSQL untuk produksi)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  /// Alamat publik dompet Solana (Pump.fun) setelah dihubungkan
  wallet        String?
  projects      Project[]
  escrowBuys    EscrowOrder[] @relation("BuyerOrders")
  escrowSales   EscrowOrder[] @relation("SellerOrders")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token      String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortPitch     String
  description    String
  groupType      String   @default("PUBLIC")
  accessType     String   @default("FREE")
  priceUsd       Float?
  category       String?
  memberCount    Int?
  rules          String   @default("")
  deliveryPolicy String   @default("")
  xCommunity     String?
  telegram       String?
  discord        String?
  launchPlan     String   @default("")
  expectedLaunch String?
  launchStatus   String   @default("UPCOMING")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  escrowOrders   EscrowOrder[]
}

model EscrowOrder {
  id          String   @id @default(cuid())
  projectId   String
  buyerId     String
  sellerId    String
  amountUsd   Float
  status      String   @default("FUNDED")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  releasedAt  DateTime?

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buyer       User     @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  seller      User     @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
}

